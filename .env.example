# =============================================================================
# autoyield — V1d service config
# =============================================================================

# --- HTTP server ---
PORT=3030

# Demo bearer-token table: "token1:userA,token2:userB".
# LOCAL DEV ONLY — this is a static auth bypass. It is IGNORED when
# NODE_ENV=production, and it must NEVER be set in production. Leave it
# commented out; real users authenticate with Phantom-issued ak_ keys.
#   DEMO_TOKENS=token1:alice

# Comma-separated list of allowed origins for CORS. Empty = allow all (dev).
# Production MUST restrict to the sign-page origins:
#   ALLOWED_ORIGINS=https://autoyield.org,https://www.autoyield.org
ALLOWED_ORIGINS=

# Web base URL — used in sign URLs returned by build_*_tx tools.
# Production: https://autoyield.org (or wherever the sign page is served).
WEB_BASE_URL=http://localhost:5173

# --- Solana RPC ---
# Primary endpoint. Recommend Helius / Quicknode / Triton paid endpoint for
# reliability. Free public endpoints (mainnet-beta, publicnode) are tried last
# automatically.
#   SOL_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOL_RPC=

# Optional fallbacks (used in order if primary fails with transient error)
SOL_RPC_FALLBACK_1=
SOL_RPC_FALLBACK_2=

# --- Persistence (sign-store + audit log) ---
# Local dev defaults to ./data/. The Dockerfile/fly.toml overrides these to
# /data/* so the Fly volume catches them across deploys.
SIGN_STORE_PATH=data/sign-store.json
AUDIT_LOG_PATH=data/audit.log
# Where hashed api-keys persist. The Dockerfile sets this to /data/api-keys.json
# (on the Fly volume); omitting it previously caused a key-wipe on deploy. Keep
# it pointed at the persistent volume in production.
AUTH_STORE_PATH=/data/api-keys.json

# --- Error monitoring (Sentry) ---
# Optional. When set, server-side 500s and broadcast failures are reported
# with sanitized context (no api keys, no signed tx blobs, no request bodies).
# Leave blank in dev to silence outbound network entirely.
#   SENTRY_DSN=https://<key>@oXXXXXX.ingest.sentry.io/XXXXXX
#   SENTRY_RELEASE=<git-sha>           # optional, set in CI for release tracking
SENTRY_DSN=

# WYSIWYS pre-broadcast simulation check. ENFORCING BY DEFAULT (even when
# unset): every signed tx is re-simulated server-side before broadcast, and
# txs whose simulated balance changes diverge grossly from the reviewed deal
# are blocked (also fail-closed on missing verification recipe / outright
# simulation failure; native-SOL spend bounded at 0.05 SOL). Set to "false"
# ONLY for shadow/log-only debugging (logs the verdict, never blocks).
PREFLIGHT_ENFORCE=true

# Public origin used for OAuth metadata + sign URLs returned to clients.
# Production: the externally reachable API origin.
#   PUBLIC_ORIGIN=https://autoyield-api.fly.dev
PUBLIC_ORIGIN=

# Per-RPC-call timeout in milliseconds (each attempt in the fallback pool).
RPC_CALL_TIMEOUT_MS=8000
