# --- Chain / infra ---
RPC_URL=https://sepolia.base.org
BUNDLER_URL=https://rpc.zerodev.app/api/v3/YOUR_PROJECT_ID/chain/84532
PAYMASTER_URL=https://rpc.zerodev.app/api/v3/YOUR_PROJECT_ID/chain/84532

# --- Agent secret (single, shared across users) ---
# Even if leaked, blast radius is bounded by every user's policy.
AGENT_SESSION_PK=

# --- Single-user stdio mode only (mcp:stdio) ---
USER_OWNER_PK=
KERNEL_ACCOUNT_ADDRESS=
SESSION_APPROVAL=

# --- HTTP MCP / multi-tenant ---
PORT=3030
# Demo bearer-token table: "token1:userA,token2:userB"
# Production: replace with OAuth/JWT (Auth0, Clerk, WorkOS).
DEMO_TOKENS=

# --- Risk providers (optional but recommended) ---
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_KEY=
