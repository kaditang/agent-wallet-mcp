{
  "name": "@kaditang/agent-wallet-mcp",
  "version": "0.2.1",
  "mcpName": "io.github.kaditang/agent-wallet-mcp",
  "type": "module",
  "description": "Non-custodial RWA + yield service for AI agents on Solana. Compare yields, quote/buy/sell tokenized US equities (Backed xStocks) and tokenized treasuries (Ondo USDY). User signs in their own wallet — we never sign.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "solana",
    "rwa",
    "tokenized-stocks",
    "xstocks",
    "ondo",
    "usdy",
    "jupiter",
    "yield",
    "defi"
  ],
  "homepage": "https://autoyield.org",
  "license": "MIT",
  "main": "dist/server/index.js",
  "bin": {
    "agent-wallet-mcp": "./dist/server/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "mcp-manifest.json"
  ],
  "scripts": {
    "mcp:http": "tsx src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "snapshot": "tsx scripts/snapshot-microstructure.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "uuid": "^9.0.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@sentry/node": "^9.0.0",
    "@solana/web3.js": "^1.98.4",
    "@types/cors": "^2.8.19",
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.1",
    "tslib": "^2.8.1",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@types/supertest": "^6.0.2",
    "jsdom": "^25.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
